{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flask: Run Development Server",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "run.py",
        "FLASK_ENV": "development",
        "FLASK_DEBUG": "1"
      },
      "args": ["run", "--host=0.0.0.0", "--port=5000", "--debugger", "--reload"],
      "jinja": true,
      "justMyCode": true
    },
    {
      "name": "Python: Run run.py directly",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run.py",
      "console": "integratedTerminal",
      "env": {
        "FLASK_ENV": "development",
        "FLASK_DEBUG": "1"
      },
      "justMyCode": false
    },
    {
      "name": "pytest: Run All Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests/",
        "-v",
        "--tb=short"
      ],
      "env": {
        "FLASK_ENV": "testing"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "pytest: Current Test File",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "${file}",
        "-v",
        "--tb=long"
      ],
      "env": {
        "FLASK_ENV": "testing"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "pytest: Unit Tests Only",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests/unit/",
        "-v"
      ],
      "env": {
        "FLASK_ENV": "testing"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "pytest: Integration Tests Only",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests/integration/",
        "-v"
      ],
      "env": {
        "FLASK_ENV": "testing"
      },
      "console": "integratedTerminal"
    }
  ]
}