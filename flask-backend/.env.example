# ─── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# ─── Security — CHANGE THESE in production ────────────────────────────────────
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=2592000   # 30 days in seconds

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite is the default — no installation needed.
# The database file is created automatically at flask-backend/website_builder.db
# To use a custom path:
# DATABASE_URL=sqlite:///path/to/your/database.db
#
# To use PostgreSQL in production (optional):
# DATABASE_URL=postgresql://user:password@localhost:5432/website_builder

# ─── Stripe Payments (optional — only needed for payment features) ────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000