{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flask: Debug Backend",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/flask-backend/run.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/flask-backend",
      "env": {
        "FLASK_APP": "run.py",
        "FLASK_ENV": "development",
        "FLASK_DEBUG": "1",
        "FLASK_RUN_PORT": "5050",
        "DATABASE_URL": "sqlite:///website_builder.db",
        "SECRET_KEY": "dev-secret-key-change-in-production",
        "JWT_SECRET_KEY": "jwt-secret-key-change-in-production"
      },
      "args": ["run"],
      "justMyCode": false,
      "preLaunchTask": "Flask: Install Dependencies"
    },
    {
      "name": "Flask: Run Backend (no debug)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/flask-backend/run.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/flask-backend",
      "env": {
        "FLASK_APP": "run.py",
        "FLASK_ENV": "development",
        "FLASK_RUN_PORT": "5050",
        "DATABASE_URL": "sqlite:///website_builder.db",
        "SECRET_KEY": "dev-secret-key-change-in-production",
        "JWT_SECRET_KEY": "jwt-secret-key-change-in-production"
      },
      "args": ["run"],
      "justMyCode": true,
      "noDebug": true,
      "preLaunchTask": "Flask: Install Dependencies"
    }
  ]
}